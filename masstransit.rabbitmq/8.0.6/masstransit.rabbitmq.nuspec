      </group>
      <group targetFramework="net6.0">
        <dependency id="MassTransit" version="8.0.6" exclude="Build,Analyzers" />
        <dependency id="RabbitMQ.Client" version="6.4.0" exclude="Build,Analyzers" />
      </group>
