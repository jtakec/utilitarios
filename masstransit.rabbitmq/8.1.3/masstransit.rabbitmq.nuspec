    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>mt-logo-small.png</icon>
    <readme>NuGet.README.md</readme>
    <projectUrl>https://masstransit.io/</projectUrl>
    <description>MassTransit RabbitMQ transport support; MassTransit provides a developer-focused, modern platform for creating distributed applications without complexity.</description>
