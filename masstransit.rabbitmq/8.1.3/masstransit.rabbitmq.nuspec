<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MassTransit.RabbitMQ</id>
    <version>8.1.3</version>
    <title>MassTransit.RabbitMQ</title>
