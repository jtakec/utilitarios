        <dependency id="Lamar" version="13.0.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 9.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="[6.0.0, 9.0.0)" exclude="Build,Analyzers" />
