<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Lamar.Diagnostics</id>
    <version>11.1.2</version>
    <authors>Jeremy D. Miller</authors>
    <licenseUrl>https://github.com/JasperFX/lamar/blob/master/LICENSE</licenseUrl>
    <projectUrl>http://jasperfx.github.io/lamar</projectUrl>
    <iconUrl>https://avatars2.githubusercontent.com/u/10048186?v=3&amp;s=200</iconUrl>
    <description>Adds diagnostic checks to the command line of your Lamar-enabled ASP.Net Core app</description>
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="Lamar" version="11.1.2" exclude="Build,Analyzers" />
        <dependency id="JasperFx.CodeGeneration.Commands" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="Oakton" version="6.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="Lamar" version="11.1.2" exclude="Build,Analyzers" />
        <dependency id="JasperFx.CodeGeneration.Commands" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="Oakton" version="6.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>