<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Lamar</id>
    <version>13.0.2</version>
    <authors>Jeremy D. Miller</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>http://jasperfx.github.io/lamar</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/JasperFx/JasperFx.Core/main/jasperfx-logo.jpg?raw=true</iconUrl>
    <description>Fast ASP.Net Core compatible IoC Tool, Successor to StructureMap</description>
    <repository type="git" commit="e3ddc4ffcfd05b29abf74aa6a778fb034a560b85" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="JasperFx.CodeGeneration" version="3.4.0" exclude="Build,Analyzers" />
