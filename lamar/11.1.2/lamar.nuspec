<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Lamar</id>
    <version>11.1.2</version>
    <authors>Jeremy D. Miller</authors>
    <licenseUrl>https://github.com/JasperFX/lamar/blob/master/LICENSE</licenseUrl>
    <projectUrl>http://jasperfx.github.io/lamar</projectUrl>
    <iconUrl>https://avatars2.githubusercontent.com/u/10048186?v=3&amp;s=200</iconUrl>
    <description>Fast ASP.Net Core compatible IoC Tool, Successor to StructureMap</description>
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="JasperFx.CodeGeneration" version="2.2.1" exclude="Build,Analyzers" />
        <dependency id="JasperFx.Core" version="1.2.0" exclude="Build,Analyzers" />
        <dependency id="JasperFx.TypeDiscovery" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="System.Runtime.Loader" version="4.3.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="JasperFx.CodeGeneration" version="2.2.1" exclude="Build,Analyzers" />
        <dependency id="JasperFx.Core" version="1.2.0" exclude="Build,Analyzers" />
        <dependency id="JasperFx.TypeDiscovery" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="System.Runtime.Loader" version="4.3.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>