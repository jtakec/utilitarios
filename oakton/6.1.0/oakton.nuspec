<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Oakton</id>
    <version>6.1.0</version>
    <authors>Jeremy D. Miller</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://jasperfx.github.io/oakton</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/JasperFx/JasperFx.Core/main/jasperfx-logo.jpg?raw=true</iconUrl>
    <description>Command Line Parsing and Execution</description>
    <tags>Command Line Parsing</tags>
    <repository type="git" url="git://github.com/jasperfx/oakton" commit="cbf2cff4dbef3cdbe1e7a94b8cb5d5e792c24b4b" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="JasperFx.Core" version="1.5.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 9.0.0)" exclude="Build,Analyzers" />
        <dependency id="Spectre.Console" version="0.47.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="JasperFx.Core" version="1.5.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 9.0.0)" exclude="Build,Analyzers" />
        <dependency id="Spectre.Console" version="0.47.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="JasperFx.Core" version="1.5.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 9.0.0)" exclude="Build,Analyzers" />
        <dependency id="Spectre.Console" version="0.47.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>