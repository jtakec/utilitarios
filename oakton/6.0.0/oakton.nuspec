<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Oakton</id>
    <version>6.0.0</version>
    <authors>Jeremy D. Miller</authors>
    <licenseUrl>https://github.com/jasperfx/oakton/raw/master/LICENSE.TXT</licenseUrl>
    <icon>jasper-icon.png</icon>
    <projectUrl>https://jasperfx.github.io/oakton</projectUrl>
    <description>Command Line Parsing and Execution</description>
    <tags>Command Line Parsing</tags>
    <repository type="git" url="git://github.com/jasperfx/oakton" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="JasperFx.Core" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="JasperFx.TypeDiscovery" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="Spectre.Console" version="0.45.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="JasperFx.Core" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="JasperFx.TypeDiscovery" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting" version="[6.0.0, 8.0.0)" exclude="Build,Analyzers" />
        <dependency id="Spectre.Console" version="0.45.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>