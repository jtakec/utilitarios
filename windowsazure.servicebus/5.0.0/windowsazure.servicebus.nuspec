    <tags>ServiceBus Microsoft Azure AppFabric Messaging PubSub Publish Subscribe Queue Topic Relay Service Bus AMQP OASIS windowsazureofficial EventHub Event;</tags>
    <dependencies>
      <dependency id="Microsoft.IdentityModel.Clients.ActiveDirectory" version="3.19.8" />
      <dependency id="Microsoft.Azure.Services.AppAuthentication" version="1.0.3" />
      <dependency id="System.IdentityModel.Tokens.Jwt" version="4.0.4.403061554" />
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.ServiceModel" targetFramework=".NETFramework4.6" />
      <frameworkAssembly assemblyName="System.Xml" targetFramework=".NETFramework4.6" />
      <frameworkAssembly assemblyName="System.Runtime.Serialization" targetFramework=".NETFramework4.6" />
    </frameworkAssemblies>
  </metadata>
</package>