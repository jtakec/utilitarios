<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.FluentUI.AspNetCore.Components</id>
    <version>4.0.0-preview.2</version>
    <title>Microsoft Fluent UI Web Components for Blazor</title>
    <authors>Microsoft</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/microsoft/fluentui-blazor</projectUrl>
    <description>A set of Blazor components wrapping Microsoft’s official Fluent UI Web Components. They implement the latest state of the Fluent design language, are built on FAST and work in every major browser.</description>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>Web Components, Fluent UI, FAST, Blazor, .NET8</tags>
    <repository type="git" url="https://github.com/microsoft/fluentui-blazor" commit="b147f4d408947bb2c93725be6a397dded45b5752" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.AspNetCore.Components.Web" version="8.0.0-rc.2.23480.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="8.0.0-rc.2.23479.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="8.0.0-rc.2.23479.6" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Http" version="8.0.0-rc.2.23479.6" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>