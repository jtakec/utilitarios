        <dependency id="Azure.Identity" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Azure.Messaging.ServiceBus" version="7.7.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="MassTransit" version="8.0.3" exclude="Build,Analyzers" />
        <dependency id="Azure.Identity" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Azure.Messaging.ServiceBus" version="7.7.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="MassTransit" version="8.0.3" exclude="Build,Analyzers" />
        <dependency id="Azure.Identity" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Azure.Messaging.ServiceBus" version="7.7.0" exclude="Build,Analyzers" />
