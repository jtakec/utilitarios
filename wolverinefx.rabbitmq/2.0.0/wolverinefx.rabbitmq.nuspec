    <repository type="git" url="http://github.com/jasperfx/wolverine" commit="81c5721c34b613143ec99fc5cd86703cdda2bcdd" />
    <dependencies>
      <group targetFramework="net7.0">
        <dependency id="WolverineFx" version="2.0.0" exclude="Build,Analyzers" />
