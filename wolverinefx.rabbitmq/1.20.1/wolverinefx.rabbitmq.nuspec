<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>WolverineFx.RabbitMQ</id>
    <version>1.20.1</version>
    <authors>Jeremy D. Miller</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>http://github.com/jasperfx/wolverine</projectUrl>
    <iconUrl>https://github.com/JasperFx/wolverine/blob/main/docs/public/logo.png?raw=true</iconUrl>
    <description>RabbitMQ Transport for Wolverine Messaging Systems</description>
    <repository type="git" url="http://github.com/jasperfx/wolverine" commit="b4c91f254a01cdc386bad2a6c889f2af8fc0457b" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="WolverineFx" version="1.20.1" exclude="Build,Analyzers" />
        <dependency id="RabbitMQ.Client" version="6.5.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="WolverineFx" version="1.20.1" exclude="Build,Analyzers" />
        <dependency id="RabbitMQ.Client" version="6.5.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="WolverineFx" version="1.20.1" exclude="Build,Analyzers" />
        <dependency id="RabbitMQ.Client" version="6.5.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>