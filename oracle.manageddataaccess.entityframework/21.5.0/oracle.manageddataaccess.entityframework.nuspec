<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Oracle.ManagedDataAccess.EntityFramework</id>
    <version>21.5.0</version>
    <title>Oracle Data Provider for .NET, Managed Entity Framework Driver</title>
    <authors>Oracle</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="file">LICENSE.txt</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <iconUrl>https://www.oracle.com/a/tech/img/collateral/nuget-oracle.png</iconUrl>
    <description>This NuGet package is for ODP.NET, Managed Driver applications that use Code First and/or Entity Framework 6 applications. It will add the Oracle Entity Framework assembly and auto-configure for its use. Note that this package does not include ODP.NET, Managed Driver which is available as a separate NuGet package.</description>
    <summary>The ODP.NET, Managed Driver Entity Framework package for EF 6 applications.</summary>
    <copyright>2022</copyright>
    <tags>ODP.NET Oracle DB database EF Entity Framework</tags>
    <dependencies>
      <dependency id="EntityFramework" version="[6.0.0, 7.0.0)" />
      <dependency id="Oracle.ManagedDataAccess" version="[21.5.0, 22.0.0)" />
    </dependencies>
  </metadata>
</package>