<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>JasperFx.CodeGeneration.Commands</id>
    <version>1.1.1</version>
    <authors>Jeremy D. Miller,Babu Annamalai,Oskar Dudycz,Joona-Pekka Kokko</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>http://jasperfx.github.io/JasperFx.CodeGeneration</projectUrl>
    <iconUrl>https://github.com/JasperFx/JasperFx.CodeGeneration/blob/main/jasper-icon.png?raw=true</iconUrl>
    <description>Command line utilities for managing Lamar dynamically generated code</description>
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="JasperFx.CodeGeneration" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="JasperFx.RuntimeCompiler" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="Oakton" version="6.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="JasperFx.CodeGeneration" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="JasperFx.RuntimeCompiler" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="Oakton" version="6.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>