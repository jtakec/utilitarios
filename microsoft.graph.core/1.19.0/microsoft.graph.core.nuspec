<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.Graph.Core</id>
    <version>1.19.0</version>
    <authors>Microsoft</authors>
    <owners>Microsoft</owners>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="file">LICENSE.txt</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <projectUrl>https://developer.microsoft.com/graph</projectUrl>
    <description>Microsoft Graph Core Client Library implements core functionality used by Microsoft Graph client libraries.</description>
    <releaseNotes>- Adds request builders for the batch endpoint to the client
      - BatchRequestStep enhancements: added overloads to add BatchRequestStep using BaseRequest and HttpRequestMessage.
      - Adds ChaosHandler for testing.
      - HTTP pipeline updates overwrite existing inner handlers.
      - BatchRequestContent enhancements to enable deserialization to a given type
      - Updates to fix and use common serializer for batch content
      - Adds FileUploadTask to provide support for file/attachement upload</releaseNotes>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>Microsoft Office365 Graph GraphServiceClient Outlook OneDrive AzureAD GraphAPI Productivity SharePoint Intune SDK</tags>
    <repository url="https://github.com/microsoftgraph/msgraph-sdk-dotnet" />
    <dependencies>
      <group targetFramework="MonoAndroid7.0">
        <dependency id="Newtonsoft.Json" version="11.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Net.Http" version="4.3.3" exclude="Build,Analyzers" />
        <dependency id="System.ValueTuple" version="4.3.0" exclude="Build,Analyzers" />
        <dependency id="System.Diagnostics.DiagnosticSource" version="4.6.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework4.5">
        <dependency id="Newtonsoft.Json" version="6.0.1" exclude="Build,Analyzers" />
        <dependency id="System.ValueTuple" version="4.3.0" exclude="Build,Analyzers" />
        <dependency id="System.Diagnostics.DiagnosticSource" version="4.6.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard1.1">
        <dependency id="NETStandard.Library" version="1.6.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="9.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Net.Http" version="4.3.3" exclude="Build,Analyzers" />
        <dependency id="System.ValueTuple" version="4.3.0" exclude="Build,Analyzers" />
        <dependency id="System.Diagnostics.DiagnosticSource" version="4.6.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="Xamarin.iOS1.0">
        <dependency id="Newtonsoft.Json" version="11.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Net.Http" version="4.3.3" exclude="Build,Analyzers" />
        <dependency id="System.Diagnostics.DiagnosticSource" version="4.6.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="Java.Interop" targetFramework="MonoAndroid7.0" />
      <frameworkAssembly assemblyName="Microsoft.CSharp" targetFramework="MonoAndroid7.0, .NETFramework4.5, Xamarin.iOS1.0" />
      <frameworkAssembly assemblyName="Mono.Android" targetFramework="MonoAndroid7.0" />
      <frameworkAssembly assemblyName="System.Core" targetFramework="MonoAndroid7.0, Xamarin.iOS1.0" />
      <frameworkAssembly assemblyName="System" targetFramework="MonoAndroid7.0, .NETFramework4.5, Xamarin.iOS1.0" />
      <frameworkAssembly assemblyName="System.Xml" targetFramework="MonoAndroid7.0, Xamarin.iOS1.0" />
      <frameworkAssembly assemblyName="System.Net.Http" targetFramework=".NETFramework4.5" />
      <frameworkAssembly assemblyName="Xamarin.iOS" targetFramework="Xamarin.iOS1.0" />
    </frameworkAssemblies>
  </metadata>
</package>